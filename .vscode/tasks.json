{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run RGBMatrix Server (sudo)",
      "type": "shell",
      "command": "sudo",
      "args": [
        "-E",
        "${command:python.interpreterPath}",
        "-m",
        "debugpy",
        "--listen",
        "127.0.0.1:5678",
        "--wait-for-client",
        "${workspaceFolder}/pi_server.py"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
